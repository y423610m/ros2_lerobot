<?xml version="1.0"?>
<robot name="container">
  <!-- Materials -->
  <material name="container_color">
    <color rgba="0.8 0.8 0.9 1.0"/> <!-- Light blue-gray -->
  </material>

  <!-- Container with 4 side walls -->
  <link name="container">
    <visual>
      <geometry>
        <mesh filename="package://lerobot_robots_description/meshes/container_visual.stl"/>
      </geometry>
      <material name="container_color"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://lerobot_robots_description/meshes/container_collision.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/> <!-- Light container -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
</robot>