<mujoco model="block_picking">
  <!--
    SO-101 robot arm: 6 DOF (joint1..joint6), where joint6 is the gripper finger.
    Single finger gripper — no coupling, no symmetric logic.

    Joint layout:
      shoulder_pan - base yaw          (Z axis)
      shoulder_lift - shoulder pitch    (Y axis)
      elbow_flex - elbow pitch       (Y axis)
      wrist_flex - wrist pitch       (Y axis)
      wrist_roll - wrist roll        (X axis)
      gripper - gripper finger    (slide, Y axis)

    Scene:
      - Table at x=0.3, surface Z=0.42
      - Block (free body) on table
      - Target zone at x=0.3, y=0.2, Z=0.423
  -->

  <include file="../../src/lerobot_robots_description/urdf/SO101/so101_new_calib.xml"/>

  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <default>
    <joint armature="0.01" damping="1.0" limited="true"/>
    <geom condim="3" friction="1 0.5 0.5" solimp="0.99 0.99 0.01" solref="0.01 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="arm_link"    rgba="0.35 0.35 0.40 1"/>
    <material name="gripper_mat" rgba="0.20 0.20 0.25 1"/>
    <material name="block_mat"   rgba="0.90 0.30 0.10 1"/>
    <material name="target_mat"  rgba="0.10 0.80 0.30 0.35"/>
    <material name="table_mat"   rgba="0.60 0.50 0.40 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.05" material="groundplane"/>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"
           specular="0.3 0.3 0.3" directional="true"/>
    <light pos="-0.5 0.5 1.2" dir="0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Table -->
    <body name="table" pos="0 0 0">
      <geom name="table_top" type="box" size="0.6 0.275 0.025"
            pos="0 0 0.8" material="table_mat"/>
      <geom name="leg_fl" type="cylinder" size="0.02 0.2" pos="-0.25 -0.25 0.2" rgba="0.5 0.4 0.3 1"/>
      <geom name="leg_fr" type="cylinder" size="0.02 0.2" pos=" 0.25 -0.25 0.2" rgba="0.5 0.4 0.3 1"/>
      <geom name="leg_bl" type="cylinder" size="0.02 0.2" pos="-0.25  0.25 0.2" rgba="0.5 0.4 0.3 1"/>
      <geom name="leg_br" type="cylinder" size="0.02 0.2" pos=" 0.25  0.25 0.2" rgba="0.5 0.4 0.3 1"/>
    </body>

    <!-- Target zone (visual only) -->
    <body name="target_zone" pos="-0.4 -0.2 0.825">
      <geom name="target_vis" type="box" size="0.05 0.05 0.002"
            material="target_mat" contype="0" conaffinity="0"/>
    </body>

    <!-- Block -->
    <body name="block" pos="0.3 0 0.447">
      <freejoint name="block_joint"/>
      <geom name="block_geom" type="box" size="0.024 0.024 0.024"
            material="block_mat" mass="0.05" friction="1.5 0.5 0.5"/>
      <site name="block_site" pos="0 0 0" size="0.005"/>
    </body>

  </worldbody>

  <!-- 6 actuators, one per joint, uniform treatment -->
  <actuator>
    <motor name="act_shoulder_pan" joint="shoulder_pan" gear="60"/>
    <motor name="act_shoulder_lift" joint="shoulder_lift" gear="60"/>
    <motor name="act_elbow_flex" joint="elbow_flex" gear="40"/>
    <motor name="act_wrist_flex" joint="wrist_flex" gear="20"/>
    <motor name="act_wrist_roll" joint="wrist_roll" gear="10"/>
    <motor name="act_gripper" joint="gripper" gear="4"/>
  </actuator>

  <sensor>
    <framepos    name="ee_pos"    objtype="site" objname="gripperframe"/>
    <framequat   name="ee_quat"   objtype="site" objname="gripperframe"/>
    <framepos    name="block_pos" objtype="site" objname="block_site"/>
    <framelinvel name="block_vel" objtype="site" objname="block_site"/>
  </sensor>

</mujoco>
